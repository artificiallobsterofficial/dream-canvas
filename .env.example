# AI Provider — set one (or both; Anthropic is preferred when both are present).
# The app works fully without any key: AI features fall back to built-in local responses.
#
# WARNING: in a browser-only app these keys are visible to anyone who opens dev tools.
# Fine for personal/local use — do NOT deploy a build containing real keys to a public URL.
VITE_ANTHROPIC_API_KEY=
VITE_GEMINI_API_KEY=

# Optional model overrides
VITE_ANTHROPIC_MODEL=claude-opus-4-8
VITE_GEMINI_MODEL=gemini-2.5-flash
